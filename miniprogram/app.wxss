@import "./styles/tokens.wxss";

page {
  min-height: 100vh;
  color: var(--ink);
  background:
    linear-gradient(90deg, rgba(102, 72, 42, 0.05) 1px, transparent 1px) 0 0 / 28rpx 28rpx,
    radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.38), transparent 34%),
    linear-gradient(180deg, #d7c0a1 0%, #f4eadb 46%, #d1ad83 100%);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei UI", sans-serif;
}

view,
text,
button,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}
