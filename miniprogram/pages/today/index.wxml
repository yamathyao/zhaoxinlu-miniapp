<view class="today-page scene-{{scene}} focus-{{pendingType}}">
  <view class="intro-curtain" wx:if="{{scene === 'intro'}}" bindtap="enterDesk">
    <text class="intro-kicker">收念匣</text>
    <text class="intro-line">{{dailyLine}}</text>
    <text class="intro-hint">轻触启匣</text>
  </view>

  <view class="titlebar">
    <text class="kicker">双匣试作</text>
    <text class="title">今日一念，收归两匣</text>
    <text class="date">{{displayDate}}</text>
  </view>

  <view class="desk-stage">
    <view class="stage-glow"></view>
    <view class="flying-slip flying-{{pendingType}} {{scene === 'sending' ? 'is-flying' : ''}}">
      <text>{{flyingText}}</text>
    </view>

    <view class="box-grid">
      <merit-box type="gong" title="功匣" count="{{today.gong.length}}" slips="{{today.gong}}" sealed="{{today.sealed}}" />
      <merit-box type="guo" title="过匣" count="{{today.guo.length}}" slips="{{today.guo}}" sealed="{{today.sealed}}" />
    </view>


    <paper-slip
      mode="stage"
      visible="{{editorVisible}}"
      type="{{pendingType}}"
      title="{{editorCopy.title}}"
      placeholder="{{editorCopy.placeholder}}"
      submitText="{{editorCopy.submit}}"
      disabled="{{scene === 'sending'}}"
      bind:cancel="closeEditor"
      bind:submit="submitSlip"
    />
  </view>

  <view class="judgement-panel">
    <text class="panel-kicker">今日评语</text>
    <text class="panel-title">{{judgement.title}}</text>
    <text class="panel-copy">{{judgement.copy}}</text>
  </view>

  <action-bar
    sealed="{{today.sealed}}"
    bind:addgong="openGong"
    bind:addguo="openGuo"
    bind:summary="goSummary"
    bind:archive="goArchive"
    bind:seal="seal"
  />
</view>
