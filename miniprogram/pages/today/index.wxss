@import "../../styles/tokens.wxss";

.today-page {
  min-height: 100vh;
  padding: 40rpx 28rpx 180rpx;
}

.titlebar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.kicker,
.date,
.panel-kicker {
  color: var(--muted);
  font-size: 24rpx;
}

.title {
  color: var(--ink);
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.18;
}

.box-grid {
  display: flex;
  gap: 22rpx;
}

.box-grid merit-box {
  flex: 1;
  min-width: 0;
}

.judgement-panel {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 28rpx;
  padding: 30rpx;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  background: rgba(255, 250, 240, 0.72);
  box-shadow: 0 18rpx 48rpx var(--shadow);
}

.panel-title {
  color: var(--ink);
  font-size: 38rpx;
  font-weight: 700;
}

.panel-copy {
  color: var(--muted);
  font-size: 28rpx;
  line-height: 1.7;
}
