@import "../../styles/tokens.wxss";

.today-page {
  position: relative;
  min-height: 100vh;
  padding: 40rpx 28rpx 292rpx;
  overflow: hidden;
}

.page-skin {
  position: absolute;
  inset: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  opacity: 0.92;
  pointer-events: none;
}

.today-page::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 0;
  background:
    radial-gradient(circle at 20% 18%, rgba(255, 250, 240, 0.5), transparent 22%),
    radial-gradient(circle at 82% 28%, rgba(186, 74, 55, 0.13), transparent 20%),
    linear-gradient(180deg, rgba(255, 250, 240, 0.12), transparent 44%);
  pointer-events: none;
}

.intro-curtain {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  padding: 80rpx;
  color: var(--ink);
  text-align: center;
  background:
    linear-gradient(90deg, rgba(120, 90, 52, 0.06) 1rpx, transparent 1rpx) 0 0 / 26rpx 26rpx,
    linear-gradient(180deg, rgba(255, 250, 240, 0.96), rgba(232, 205, 166, 0.96));
  animation: curtainIn 520ms ease both;
}

.intro-kicker {
  color: var(--muted);
  font-size: 28rpx;
  letter-spacing: 6rpx;
}

.intro-line {
  max-width: 560rpx;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.38;
}

.intro-hint {
  margin-top: 30rpx;
  padding: 18rpx 34rpx;
  border: 1rpx solid rgba(76, 48, 36, 0.18);
  border-radius: 999rpx;
  color: var(--wood-deep);
  font-size: 26rpx;
  background: rgba(255, 250, 240, 0.58);
  animation: hintPulse 1600ms ease-in-out infinite;
}

.titlebar {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.kicker,
.date,
.panel-kicker {
  color: var(--muted);
  font-size: 24rpx;
}

.title {
  color: var(--ink);
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.18;
}

.has-modal .titlebar,
.has-modal .desk-stage,
.has-modal .judgement-panel,
.has-modal action-bar {
  opacity: 0.42;
  pointer-events: none;
  filter: blur(1rpx);
}

.desk-stage {
  position: relative;
  z-index: 1;
  min-height: 470rpx;
  padding: 24rpx 0 10rpx;
}

.stage-glow {
  position: absolute;
  left: 12%;
  right: 12%;
  top: 110rpx;
  height: 340rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 236, 188, 0.48), transparent 62%);
  filter: blur(8rpx);
  pointer-events: none;
}

.box-grid {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 22rpx;
  will-change: transform;
  transform: translateZ(0);
  transition: transform 320ms cubic-bezier(.2, .82, .22, 1), opacity 300ms ease;
}

.box-grid merit-box {
  flex: 1;
  min-width: 0;
}

.scene-writing.focus-gong .box-grid {
  transform: translateX(166rpx) translateY(24rpx) scale(1.22);
}

.scene-writing.focus-guo .box-grid {
  transform: translateX(-166rpx) translateY(24rpx) scale(1.22);
}

.scene-sending.focus-gong .box-grid {
  transform: translateX(118rpx) translateY(18rpx) scale(1.12);
}

.scene-sending.focus-guo .box-grid {
  transform: translateX(-118rpx) translateY(18rpx) scale(1.12);
}

.flying-slip {
  position: absolute;
  left: 50%;
  bottom: 52rpx;
  z-index: 8;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 54rpx;
  height: 172rpx;
  padding: 20rpx 8rpx 14rpx;
  border-radius: 999rpx 999rpx 10rpx 10rpx;
  color: rgba(47, 37, 29, 0.86);
  font-size: 18rpx;
  line-height: 1.18;
  writing-mode: vertical-rl;
  letter-spacing: 1rpx;
  overflow: hidden;
  opacity: 0;
  pointer-events: none;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5),
    0 8rpx 18rpx rgba(47, 31, 20, 0.16);
  will-change: transform, opacity;
  transform: translateZ(0);
}

.flying-slip text {
  display: block;
  max-height: 124rpx;
  overflow: hidden;
}

.flying-slip::before {
  content: "";
  position: absolute;
  top: 10rpx;
  left: 50%;
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(92, 58, 31, 0.22);
  transform: translateX(-50%);
}

.flying-slip::after {
  content: "";
  position: absolute;
  right: 8rpx;
  bottom: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 4rpx;
  opacity: 0.68;
}

.flying-gong {
  background:
    linear-gradient(90deg, rgba(137, 91, 48, 0.08) 1rpx, transparent 1rpx) 0 0 / 10rpx 10rpx,
    linear-gradient(180deg, #fff4dd, #eac59f);
  border: 1rpx solid rgba(186, 74, 55, 0.2);
}

.flying-gong::after {
  background: rgba(186, 74, 55, 0.42);
}

.flying-guo {
  background:
    linear-gradient(90deg, rgba(72, 111, 122, 0.08) 1rpx, transparent 1rpx) 0 0 / 10rpx 10rpx,
    linear-gradient(180deg, #eff6ef, #b7cfcb);
  border: 1rpx solid rgba(72, 111, 122, 0.22);
}

.flying-guo::after {
  background: rgba(72, 111, 122, 0.42);
}

.flying-slip.is-flying {
  animation: flyToGong 760ms cubic-bezier(.2, .78, .2, 1) both;
}

.focus-guo .flying-slip.is-flying {
  animation-name: flyToGuo;
}
.judgement-panel {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 0;
  padding: 30rpx;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  background: rgba(255, 250, 240, 0.72);
  box-shadow: 0 18rpx 48rpx var(--shadow);
}

.heart-lamp-wrap {
  position: relative;
  z-index: 3;
  display: flex;
  justify-content: center;
  height: 132rpx;
  margin: 54rpx 0 26rpx;
  pointer-events: none;
}

.heart-lamp-image {
  width: 108rpx;
  height: 132rpx;
  filter: drop-shadow(0 12rpx 22rpx rgba(72, 43, 22, 0.18));
  opacity: 0.82;
}


.lamp-bright.lamp-level-1 .heart-lamp-image,
.lamp-bright.lamp-level-1 .heart-lamp {
  opacity: 0.9;
  filter: saturate(1.08) brightness(1.06) drop-shadow(0 12rpx 24rpx rgba(197, 135, 44, 0.22));
}

.lamp-bright.lamp-level-3 .heart-lamp-image,
.lamp-bright.lamp-level-3 .heart-lamp {
  opacity: 0.96;
  filter: saturate(1.18) brightness(1.12) drop-shadow(0 14rpx 28rpx rgba(211, 142, 48, 0.28));
}

.lamp-bright.lamp-level-5 .heart-lamp-image,
.lamp-bright.lamp-level-5 .heart-lamp {
  opacity: 1;
  filter: saturate(1.3) brightness(1.2) drop-shadow(0 16rpx 34rpx rgba(224, 154, 55, 0.36));
}

.lamp-bright.lamp-level-10 .heart-lamp-image,
.lamp-bright.lamp-level-10 .heart-lamp {
  opacity: 1;
  filter: saturate(1.46) brightness(1.34) drop-shadow(0 18rpx 44rpx rgba(238, 171, 64, 0.5));
}

.lamp-dim.lamp-level-1 .heart-lamp-image,
.lamp-dim.lamp-level-1 .heart-lamp {
  opacity: 0.76;
  filter: saturate(0.86) brightness(0.92) drop-shadow(0 10rpx 20rpx rgba(49, 68, 72, 0.2));
}

.lamp-dim.lamp-level-3 .heart-lamp-image,
.lamp-dim.lamp-level-3 .heart-lamp {
  opacity: 0.66;
  filter: saturate(0.72) brightness(0.82) drop-shadow(0 8rpx 18rpx rgba(37, 54, 60, 0.22));
}

.lamp-dim.lamp-level-5 .heart-lamp-image,
.lamp-dim.lamp-level-5 .heart-lamp {
  opacity: 0.56;
  filter: saturate(0.58) brightness(0.72) drop-shadow(0 6rpx 16rpx rgba(30, 45, 52, 0.24));
}

.lamp-dim.lamp-level-10 .heart-lamp-image,
.lamp-dim.lamp-level-10 .heart-lamp {
  opacity: 0.46;
  filter: saturate(0.44) brightness(0.62) drop-shadow(0 4rpx 12rpx rgba(24, 34, 42, 0.26));
}
.heart-lamp {
  position: relative;
  width: 96rpx;
  height: 120rpx;
  filter: drop-shadow(0 12rpx 22rpx rgba(72, 43, 22, 0.18));
  opacity: 0.82;
}

.heart-lamp::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 0;
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 210, 116, 0.58), transparent 68%);
  transform: translateX(-50%);
  animation: lampGlow 1800ms ease-in-out infinite;
}

.lamp-flame {
  position: absolute;
  left: 50%;
  top: 18rpx;
  z-index: 2;
  width: 30rpx;
  height: 48rpx;
  border-radius: 999rpx 999rpx 999rpx 18rpx;
  background: linear-gradient(180deg, #fff6ba, #f4a84f 68%, #ba4a37);
  transform: translateX(-50%) rotate(8deg);
  transform-origin: 50% 85%;
  animation: flameBreath 1500ms ease-in-out infinite;
}

.lamp-bowl {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  width: 78rpx;
  height: 38rpx;
  border-radius: 8rpx 8rpx 36rpx 36rpx;
  background:
    linear-gradient(180deg, rgba(255, 240, 198, 0.36), transparent 48%),
    linear-gradient(180deg, var(--brass), var(--brass-dark));
  transform: translateX(-50%);
  box-shadow: inset 0 -6rpx 10rpx rgba(52, 31, 15, 0.18);
}

.judgement-guo .lamp-flame {
  background: linear-gradient(180deg, #fff7c5, #d7a35a 62%, var(--guo));
}

.judgement-balanced .lamp-flame {
  background: linear-gradient(180deg, #fff7c5, var(--brass) 62%, var(--wood));
}

.judgement-empty .lamp-flame {
  opacity: 0.72;
  filter: saturate(0.72);
}
.panel-title {
  color: var(--ink);
  font-size: 38rpx;
  font-weight: 700;
}

.panel-copy {
  color: var(--muted);
  font-size: 28rpx;
  line-height: 1.7;
}

@keyframes lampGlow {
  0%,
  100% {
    opacity: 0.64;
    transform: translateX(-50%) scale(0.94);
  }

  50% {
    opacity: 1;
    transform: translateX(-50%) scale(1.08);
  }
}

@keyframes flameBreath {
  0%,
  100% {
    transform: translateX(-50%) rotate(6deg) scaleY(0.96);
  }

  50% {
    transform: translateX(-50%) rotate(-4deg) scaleY(1.08);
  }
}
@keyframes curtainIn {
  from {
    opacity: 0;
    transform: scale(1.02);
  }

  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes hintPulse {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-6rpx);
  }
}

@keyframes flyToGong {
  0% {
    opacity: 0;
    transform: translate(-50%, 0) rotate(-3deg) scale(1);
  }

  18% {
    opacity: 1;
  }

  58% {
    transform: translate(-210rpx, -210rpx) rotate(12deg) scale(0.82);
  }

  100% {
    opacity: 0;
    transform: translate(-275rpx, -360rpx) rotate(-8deg) scale(0.28);
  }
}

@keyframes flyToGuo {
  0% {
    opacity: 0;
    transform: translate(-50%, 0) rotate(3deg) scale(1);
  }

  18% {
    opacity: 1;
  }

  58% {
    transform: translate(86rpx, -210rpx) rotate(-12deg) scale(0.82);
  }

  100% {
    opacity: 0;
    transform: translate(150rpx, -360rpx) rotate(8deg) scale(0.28);
  }
}
.box-viewer-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100vw;
  min-height: 100vh;
  padding: 42rpx 30rpx;
  background:
    radial-gradient(circle at 50% 34%, rgba(255, 236, 188, 0.22), transparent 38%),
    rgba(37, 28, 22, 0.68);
  opacity: 0;
  animation: viewerMaskIn 220ms ease forwards;
}

.box-viewer {
  position: relative;
  box-sizing: border-box;
  width: 100%;
  max-width: 680rpx;
  max-height: 84vh;
  padding: 54rpx 30rpx 30rpx;
  border-radius: 32rpx;
  background:
    linear-gradient(115deg, rgba(255, 255, 255, 0.16), transparent 30%),
    linear-gradient(160deg, rgba(255, 250, 240, 0.96), rgba(217, 194, 160, 0.94)),
    var(--paper);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.36),
    0 44rpx 112rpx rgba(20, 13, 8, 0.46);
  overflow: visible;
  animation: viewerBoxIn 340ms cubic-bezier(.2, .78, .2, 1) both;
}

.box-viewer::after {
  content: "";
  position: absolute;
  left: 11%;
  right: 11%;
  top: 108rpx;
  z-index: 2;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(45, 28, 18, 0.2);
  box-shadow: 0 12rpx 24rpx rgba(45, 28, 18, 0.18);
}

.viewer-lid {
  position: absolute;
  left: 9%;
  top: -30rpx;
  z-index: 3;
  width: 82%;
  height: 104rpx;
  border-radius: 26rpx 26rpx 36rpx 36rpx;
  background:
    radial-gradient(ellipse at 34% 18%, rgba(255, 229, 174, 0.28), transparent 34%),
    repeating-linear-gradient(96deg, rgba(255, 239, 198, 0.08) 0 3rpx, rgba(73, 43, 23, 0.08) 4rpx 8rpx),
    linear-gradient(180deg, #b57b4d 0%, #7d4b31 58%, var(--wood-deep) 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 235, 186, 0.22),
    0 24rpx 40rpx rgba(43, 26, 15, 0.28);
  transform: rotateX(18deg);
  transform-origin: 50% 100%;
}

.viewer-header {
  position: relative;
  z-index: 4;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 34rpx;
  margin-bottom: 24rpx;
}

.viewer-kicker {
  color: var(--ink);
  font-size: 42rpx;
  font-weight: 700;
}

.viewer-count {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: var(--muted);
  background: rgba(255, 250, 240, 0.58);
  font-size: 24rpx;
}

.viewer-body {
  position: relative;
  z-index: 4;
}

.viewer-mouth {
  box-sizing: border-box;
  min-height: 386rpx;
  max-height: 512rpx;
  padding: 30rpx 24rpx;
  border: 1rpx solid rgba(76, 48, 36, 0.14);
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 50% 14%, rgba(255, 245, 213, 0.48), transparent 42%),
    linear-gradient(180deg, rgba(83, 50, 28, 0.16), rgba(67, 38, 22, 0.3));
  box-shadow: inset 0 24rpx 36rpx rgba(45, 28, 18, 0.1);
  overflow-y: auto;
}

.viewer-slip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  align-content: flex-start;
}

.viewer-slip {
  position: relative;
  box-sizing: border-box;
  width: 88rpx;
  height: 340rpx;
  padding: 32rpx 10rpx 20rpx;
  border-radius: 999rpx 999rpx 12rpx 12rpx;
  color: rgba(47, 37, 29, 0.88);
  writing-mode: vertical-rl;
  letter-spacing: 1rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.48),
    0 10rpx 22rpx rgba(47, 31, 20, 0.18);
  transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease;
}

.viewer-slip.slip-gong {
  background:
    linear-gradient(90deg, rgba(137, 91, 48, 0.08) 1rpx, transparent 1rpx) 0 0 / 10rpx 10rpx,
    linear-gradient(180deg, #fff4dd, #eac59f);
  border: 1rpx solid rgba(186, 74, 55, 0.22);
}

.viewer-slip.slip-gong::after {
  background: rgba(186, 74, 55, 0.44);
}

.viewer-slip.slip-guo {
  background:
    linear-gradient(90deg, rgba(72, 111, 122, 0.08) 1rpx, transparent 1rpx) 0 0 / 10rpx 10rpx,
    linear-gradient(180deg, #eff6ef, #b7cfcb);
  border: 1rpx solid rgba(72, 111, 122, 0.24);
}

.viewer-slip.slip-guo::after {
  background: rgba(72, 111, 122, 0.44);
}
.viewer-slip.is-selected {
  transform: translateY(-10rpx) scale(1.08);
  filter: saturate(1.08) brightness(1.04);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.56),
    0 20rpx 38rpx rgba(47, 31, 20, 0.28);
}

.viewer-slip::before {
  content: "";
  position: absolute;
  top: 12rpx;
  left: 50%;
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(92, 58, 31, 0.24);
  transform: translateX(-50%);
}

.viewer-slip::after {
  content: "";
  position: absolute;
  right: 10rpx;
  bottom: 12rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 4rpx;
  opacity: 0.66;
}

.viewer-slip-label {
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.1;
}

.viewer-slip-preview {
  margin-top: 10rpx;
  font-size: 18rpx;
  line-height: 1.14;
  opacity: 0.72;
}

.viewer-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
  color: rgba(255, 250, 240, 0.76);
  font-size: 28rpx;
}

.slip-detail {
  position: relative;
  z-index: 4;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid rgba(137, 91, 48, 0.18);
  border-radius: 18rpx;
  background:
    linear-gradient(90deg, rgba(120, 90, 52, 0.06) 1rpx, transparent 1rpx) 0 0 / 20rpx 20rpx,
    linear-gradient(180deg, rgba(255, 248, 233, 0.92), rgba(239, 215, 180, 0.9));
  box-shadow: 0 16rpx 34rpx rgba(47, 31, 20, 0.12);
  opacity: 0.82;
}

.slip-detail.is-visible {
  opacity: 1;
}

.detail-title {
  color: var(--muted);
  font-size: 24rpx;
}

.detail-copy {
  color: var(--ink);
  font-size: 30rpx;
  line-height: 1.72;
  word-break: break-word;
}

@keyframes viewerMaskIn {
  to {
    opacity: 1;
  }
}

@keyframes viewerBoxIn {
  from {
    opacity: 0;
    transform: translateY(34rpx) scale(0.88);
  }

  64% {
    transform: translateY(-4rpx) scale(1.02);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
