@import "../../styles/tokens.wxss";

.summary-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  text-align: center;
}

.primary-btn,
.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1;
}

.primary-btn {
  color: #fffaf0;
  background: linear-gradient(180deg, var(--wood), var(--wood-deep));
}

.ghost-btn {
  color: var(--wood-deep);
  border: 1rpx solid rgba(76, 48, 36, 0.22);
  background: rgba(255, 250, 240, 0.48);
}