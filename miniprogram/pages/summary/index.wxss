@import "../../styles/tokens.wxss";

.summary-page {
  box-sizing: border-box;
  display: flex;
  min-height: 100vh;
  padding: 48rpx 32rpx calc(300rpx + env(safe-area-inset-bottom));
  text-align: center;
}


.summary-card-slot {
  display: flex;
  flex: 1;
  min-height: calc(100vh - 348rpx - env(safe-area-inset-bottom));
}

.summary-card-slot sealed-card {
  display: block;
  flex: 1;
  min-height: 100%;
}
.summary-actions {
  position: fixed;
  right: 32rpx;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  z-index: 20;
  padding: 18rpx;
  border: 1rpx solid rgba(76, 48, 36, 0.16);
  border-radius: 28rpx;
  background: rgba(255, 250, 240, 0.86);
  box-shadow: 0 18rpx 54rpx rgba(52, 33, 19, 0.18);
}

.primary-btn,
.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1;
}

.ghost-btn {
  margin-top: 18rpx;
}

.primary-btn {
  color: #fffaf0;
  background: linear-gradient(180deg, var(--wood), var(--wood-deep));
}

.ghost-btn {
  color: var(--wood-deep);
  border: 1rpx solid rgba(76, 48, 36, 0.22);
  background: rgba(255, 250, 240, 0.48);
}
