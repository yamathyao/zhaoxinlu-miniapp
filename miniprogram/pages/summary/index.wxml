<view class="summary-page">
  <view class="summary-card-slot">
    <view class="summary-card-shell">
      <sealed-card day="{{today}}" judgement="{{judgement}}" displayDate="{{displayDate}}" copy="{{copy}}" skin="{{theme.assets}}" />
    </view>
  </view>
  <view class="summary-actions">
    <button class="primary-btn" bindtap="shareCard">{{copy.summary.shareButton}}</button>
    <button class="ghost-btn" bindtap="goArchive">{{copy.summary.archiveButton}}</button>
  </view>
</view>
