<view class="archive-page">
  <view class="header">
    <text class="kicker">{{copy.archive.kicker}}</text>
    <text class="title">{{copy.archive.title}}</text>
  </view>

  <block wx:if="{{archive.length}}">
    <view class="archive-list">
      <view class="archive-item" wx:for="{{archive}}" wx:key="dateKey">
        <view>
          <text class="date">{{item.displayDate}}</text>
          <text class="result">{{item.judgement.title}}</text>
        </view>
        <text class="counts">{{item.gong.length}} {{copy.domain.gong.slipName}} · {{item.guo.length}} {{copy.domain.guo.slipName}}</text>
        <text class="copy">{{item.judgement.copy}}</text>
      </view>
    </view>
  </block>

  <view class="empty" wx:else>
    <text>{{copy.archive.empty}}</text>
  </view>

  <view class="archive-actions" wx:if="{{!archive.length}}">
    <button bindtap="goToday">{{copy.archive.backToday}}</button>
  </view>
</view>