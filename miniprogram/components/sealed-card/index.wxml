<view class="daily-card">
  <text class="card-date">{{displayDate}}</text>
  <text class="card-title">{{judgement.title}}</text>
  <text class="card-copy">{{judgement.copy}}</text>
  <view class="card-counts">
    <text>{{day.gong.length}} {{copy.domain.gong.slipName}}</text>
    <text>{{day.guo.length}} {{copy.domain.guo.slipName}}</text>
  </view>
</view>