@import "../../styles/tokens.wxss";

.daily-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  box-sizing: border-box;
  min-height: 100%;
  padding: 80rpx 42rpx 58rpx;
  border-radius: 30rpx;
  color: var(--ink);
  overflow: hidden;
  text-align: center;
  background:
    radial-gradient(circle at 50% 18%, rgba(255, 246, 221, 0.72), transparent 32%),
    linear-gradient(90deg, rgba(120, 90, 52, 0.06) 1rpx, transparent 1rpx) 0 0 / 26rpx 26rpx,
    linear-gradient(180deg, #fff8e9, #efd7b4);
  box-shadow: 0 24rpx 68rpx var(--shadow);
}

.card-bg-skin {
  position: absolute;
  inset: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  opacity: 0.66;
  pointer-events: none;
}

.card-ribbon-skin {
  position: absolute;
  top: 34rpx;
  left: 50%;
  z-index: 1;
  width: 170rpx;
  height: 100%;
  opacity: 0.54;
  pointer-events: none;
  transform: translateX(-50%);
}

.card-seal-skin {
  position: absolute;
  right: 54rpx;
  bottom: 54rpx;
  z-index: 2;
  width: 112rpx;
  height: 112rpx;
  opacity: 0.82;
  pointer-events: none;
  transform: rotate(-8deg);
  filter: drop-shadow(0 10rpx 18rpx rgba(82, 34, 24, 0.16));
}

.card-heart-lamp-image {
  position: relative;
  z-index: 1;
  width: 104rpx;
  height: 132rpx;
  margin-top: 18rpx;
  margin-bottom: 2rpx;
  filter: drop-shadow(0 12rpx 24rpx rgba(72, 43, 22, 0.18));
  opacity: 0.82;
}

.card-date,
.card-title,
.card-copy,
.card-main,
.card-counts {
  position: relative;
  z-index: 3;
}

.lamp-bright.lamp-level-1 .card-heart-lamp-image,
.lamp-bright.lamp-level-1 .card-heart-lamp {
  opacity: 0.9;
  filter: saturate(1.08) brightness(1.06) drop-shadow(0 12rpx 24rpx rgba(197, 135, 44, 0.22));
}

.lamp-bright.lamp-level-3 .card-heart-lamp-image,
.lamp-bright.lamp-level-3 .card-heart-lamp {
  opacity: 0.96;
  filter: saturate(1.18) brightness(1.12) drop-shadow(0 14rpx 28rpx rgba(211, 142, 48, 0.28));
}

.lamp-bright.lamp-level-5 .card-heart-lamp-image,
.lamp-bright.lamp-level-5 .card-heart-lamp {
  opacity: 1;
  filter: saturate(1.3) brightness(1.2) drop-shadow(0 16rpx 34rpx rgba(224, 154, 55, 0.36));
}

.lamp-bright.lamp-level-10 .card-heart-lamp-image,
.lamp-bright.lamp-level-10 .card-heart-lamp {
  opacity: 1;
  filter: saturate(1.46) brightness(1.34) drop-shadow(0 18rpx 44rpx rgba(238, 171, 64, 0.5));
}

.lamp-dim.lamp-level-1 .card-heart-lamp-image,
.lamp-dim.lamp-level-1 .card-heart-lamp {
  opacity: 0.76;
  filter: saturate(0.86) brightness(0.92) drop-shadow(0 10rpx 20rpx rgba(49, 68, 72, 0.2));
}

.lamp-dim.lamp-level-3 .card-heart-lamp-image,
.lamp-dim.lamp-level-3 .card-heart-lamp {
  opacity: 0.66;
  filter: saturate(0.72) brightness(0.82) drop-shadow(0 8rpx 18rpx rgba(37, 54, 60, 0.22));
}

.lamp-dim.lamp-level-5 .card-heart-lamp-image,
.lamp-dim.lamp-level-5 .card-heart-lamp {
  opacity: 0.56;
  filter: saturate(0.58) brightness(0.72) drop-shadow(0 6rpx 16rpx rgba(30, 45, 52, 0.24));
}

.lamp-dim.lamp-level-10 .card-heart-lamp-image,
.lamp-dim.lamp-level-10 .card-heart-lamp {
  opacity: 0.46;
  filter: saturate(0.44) brightness(0.62) drop-shadow(0 4rpx 12rpx rgba(24, 34, 42, 0.26));
}

.card-heart-lamp {
  position: relative;
  z-index: 1;
  width: 84rpx;
  height: 104rpx;
  margin-top: 18rpx;
  margin-bottom: 2rpx;
  filter: drop-shadow(0 12rpx 24rpx rgba(72, 43, 22, 0.18));
  opacity: 0.82;
}

.card-heart-lamp::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 0;
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 211, 122, 0.62), transparent 68%);
  transform: translateX(-50%);
  animation: cardLampGlow 1800ms ease-in-out infinite;
}

.card-lamp-flame {
  position: absolute;
  left: 50%;
  top: 20rpx;
  z-index: 2;
  width: 26rpx;
  height: 42rpx;
  border-radius: 999rpx 999rpx 999rpx 18rpx;
  background: linear-gradient(180deg, #fff6ba, #f4a84f 68%, #ba4a37);
  transform: translateX(-50%) rotate(8deg);
  transform-origin: 50% 85%;
  animation: cardFlameBreath 1500ms ease-in-out infinite;
}

.card-lamp-bowl {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  width: 70rpx;
  height: 34rpx;
  border-radius: 8rpx 8rpx 36rpx 36rpx;
  background:
    linear-gradient(180deg, rgba(255, 240, 198, 0.36), transparent 48%),
    linear-gradient(180deg, var(--brass), var(--brass-dark));
  transform: translateX(-50%);
  box-shadow: inset 0 -6rpx 10rpx rgba(52, 31, 15, 0.18);
}

@keyframes cardLampGlow {
  0%,
  100% {
    opacity: 0.64;
    transform: translateX(-50%) scale(0.94);
  }

  50% {
    opacity: 1;
    transform: translateX(-50%) scale(1.08);
  }
}

@keyframes cardFlameBreath {
  0%,
  100% {
    transform: translateX(-50%) rotate(6deg) scaleY(0.96);
  }

  50% {
    transform: translateX(-50%) rotate(-4deg) scaleY(1.08);
  }
}

.card-main {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 26rpx;
  width: 100%;
  min-height: 0;
}

.card-date {
  color: var(--muted);
  font-size: 26rpx;
}

.card-title {
  max-width: 100%;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1.18;
}

.card-copy {
  max-width: 520rpx;
  color: var(--muted);
  font-size: 30rpx;
  line-height: 1.7;
}

.card-counts {
  display: flex;
  justify-content: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.card-count-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  color: var(--wood-deep);
  background: rgba(255, 250, 240, 0.7);
  font-size: 24rpx;
  line-height: 1;
}
