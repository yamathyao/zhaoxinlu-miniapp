@import "../../styles/tokens.wxss";

.daily-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  min-height: 560rpx;
  padding: 54rpx 42rpx;
  border-radius: 30rpx;
  color: var(--ink);
  text-align: center;
  background:
    radial-gradient(circle at 50% 18%, rgba(255, 246, 221, 0.72), transparent 32%),
    linear-gradient(90deg, rgba(120, 90, 52, 0.06) 1rpx, transparent 1rpx) 0 0 / 26rpx 26rpx,
    linear-gradient(180deg, #fff8e9, #efd7b4);
  box-shadow: 0 24rpx 68rpx var(--shadow);
}

.card-date {
  color: var(--muted);
  font-size: 26rpx;
}

.card-title {
  max-width: 100%;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1.18;
}

.card-copy {
  max-width: 520rpx;
  color: var(--muted);
  font-size: 30rpx;
  line-height: 1.7;
}

.card-counts {
  display: flex;
  justify-content: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.card-counts text {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  color: var(--wood-deep);
  background: rgba(255, 250, 240, 0.7);
  font-size: 24rpx;
  line-height: 1;
}