<view class="ledger-box box-{{type}} {{sealed ? 'is-sealed' : ''}}" bindtap="openBox">
  <image class="box-body-skin" wx:if="{{visualSkin.body}}" src="{{visualSkin.body}}" mode="aspectFill" />
  <view class="box-lid"></view>
  <image class="box-lid-skin" wx:if="{{visualSkin.lid}}" src="{{visualSkin.lid}}" mode="aspectFill" />
  <view class="box-mouth">
    <view class="slip-stack">
      <view class="stored-slip slip-{{type}} stack-slot-{{item.stackSlot}}" wx:for="{{stackSlips}}" wx:key="createdAt">
        <image class="stored-slip-skin" wx:if="{{visualSkin.slip}}" src="{{visualSkin.slip}}" mode="aspectFill" />
        <text class="stored-slip-text">{{item.text || emptyText}}</text>
      </view>
    </view>
  </view>
  <view class="box-base">
    <text>{{title}}</text>
    <text class="count">{{count}} {{countUnit}}</text>
  </view>
</view>
