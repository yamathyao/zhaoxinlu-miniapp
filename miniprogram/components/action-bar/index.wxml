<view class="action-bar {{sealed ? 'is-sealed' : ''}}">
  <view class="primary-actions">
    <button class="record-btn gong" disabled="{{sealed}}" bindtap="addGong">{{copy.addGong}}</button>
    <button class="record-btn guo" disabled="{{sealed}}" bindtap="addGuo">{{copy.addGuo}}</button>
  </view>
  <view class="secondary-actions">
    <button bindtap="summary">{{copy.summary}}</button>
    <button class="seal-toggle" bindtap="seal">{{sealed ? copy.unseal : copy.seal}}</button>
    <button bindtap="archive">{{copy.archive}}</button>
  </view>
</view>