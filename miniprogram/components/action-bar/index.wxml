<view class="action-bar {{sealed ? 'is-sealed' : ''}}">
  <view class="primary-actions">
    <button class="record-btn gong" disabled="{{sealed}}" bindtap="addGong">写一功</button>
    <button class="record-btn guo" disabled="{{sealed}}" bindtap="addGuo">写一过</button>
  </view>
  <view class="secondary-actions">
    <button bindtap="summary">卡片</button>
    <button class="seal-toggle" bindtap="seal">{{sealed ? '解封' : '封存'}}</button>
    <button bindtap="archive">归档</button>
  </view>
</view>
