@import "../../styles/tokens.wxss";

.paper-host {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx 34rpx;
  background: rgba(47, 37, 29, 0.42);
  opacity: 0;
  pointer-events: none;
  transition: opacity 220ms ease;
}

.paper-host.is-open {
  opacity: 1;
  pointer-events: auto;
}

.paper-host.mode-stage {
  background:
    radial-gradient(circle at 50% 42%, rgba(255, 236, 188, 0.2), transparent 34%),
    rgba(47, 37, 29, 0.46);
}

.paper-token {
  width: 100%;
  max-width: 640rpx;
  padding: 34rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(90deg, rgba(120, 90, 52, 0.06) 1rpx, transparent 1rpx) 0 0 / 22rpx 22rpx,
    linear-gradient(180deg, #fff8e9, #efd7b4);
  box-shadow: 0 34rpx 86rpx rgba(34, 24, 16, 0.34);
  transform: translateY(32rpx) scale(0.98);
  transition: transform 260ms ease, opacity 220ms ease;
}

.is-open .paper-token {
  transform: translateY(0) scale(1);
}

.mode-stage .paper-token {
  width: min(620rpx, 88vw);
  border-radius: 18rpx;
  transform: translateY(42rpx) rotate(-2deg) scale(0.94);
  opacity: 0;
}

.mode-stage.is-open .paper-token {
  animation: paperRise 420ms cubic-bezier(.2, .78, .2, 1) both;
}

.token-title {
  display: block;
  margin-bottom: 18rpx;
  color: var(--ink);
  font-size: 36rpx;
  font-weight: 700;
}

.token-text {
  width: 100%;
  min-height: 220rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  color: var(--ink);
  background: rgba(255, 250, 240, 0.76);
  font-size: 28rpx;
  line-height: 1.6;
}

.token-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.ghost-btn,
.submit-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1;
}

.ghost-btn {
  color: var(--wood-deep);
  background: rgba(255, 250, 240, 0.62);
}

.submit-btn {
  color: #fffaf0;
  background: linear-gradient(180deg, var(--wood), var(--wood-deep));
}

.ghost-btn[disabled],
.submit-btn[disabled] {
  opacity: 0.56;
}

@keyframes paperRise {
  from {
    opacity: 0;
    transform: translateY(42rpx) rotate(-5deg) scale(0.9);
  }

  to {
    opacity: 1;
    transform: translateY(0) rotate(-2deg) scale(1);
  }
}
