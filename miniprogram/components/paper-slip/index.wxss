@import "../../styles/tokens.wxss";

.paper-host {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100vw;
  min-height: 100vh;
  padding: 48rpx 34rpx;
  background:
    radial-gradient(circle at 50% 44%, rgba(255, 236, 188, 0.18), transparent 36%),
    rgba(47, 37, 29, 0.58);
  opacity: 0;
  pointer-events: none;
  transition: opacity 220ms ease;
}

.paper-host.is-open {
  opacity: 1;
  pointer-events: auto;
}

.paper-host.mode-stage:not(.is-open) {
  transition-duration: 0ms;
}

.paper-token-wrap {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 220ms ease;
}

.paper-token {
  position: relative;
  box-sizing: border-box;
  width: 540rpx;
  max-width: 540rpx;
  height: 760rpx;
  padding: 40rpx 32rpx 30rpx;
  border-radius: 22rpx;
  background:
    linear-gradient(90deg, rgba(120, 90, 52, 0.06) 1rpx, transparent 1rpx) 0 0 / 22rpx 22rpx,
    linear-gradient(180deg, #fff8e9, #efd7b4);
  box-shadow: 0 34rpx 86rpx rgba(34, 24, 16, 0.34);
  opacity: 0;
  transform: translateY(24rpx) scale(0.97);
  overflow: hidden;
}

.paper-token-skin {
  position: absolute;
  inset: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  opacity: 0.72;
  pointer-events: none;
}

.paper-host.is-open .paper-token {
  animation: paperRise 360ms cubic-bezier(.2, .78, .2, 1) forwards;
}

.mode-stage .paper-token {
  width: 520rpx;
  height: 720rpx;
  border-radius: 18rpx;
}

.token-title {
  position: relative;
  z-index: 1;
  display: block;
  margin-bottom: 16rpx;
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 700;
}

.token-text {
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  width: 100%;
  height: 460rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  color: var(--ink);
  background: rgba(255, 250, 240, 0.76);
  font-size: 28rpx;
  line-height: 1.6;
}

.token-actions {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.ghost-btn,
.submit-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1;
}

.ghost-btn {
  color: var(--wood-deep);
  background: rgba(255, 250, 240, 0.62);
}

.submit-btn {
  color: #fffaf0;
  background: linear-gradient(180deg, var(--wood), var(--wood-deep));
}

.ghost-btn.is-disabled,
.submit-btn.is-disabled {
  opacity: 0.56;
}

@keyframes paperRise {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.97);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
